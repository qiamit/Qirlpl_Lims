# --- वेब ऐप ↔ Supabase कनेक्शन ---
# 1) इस फाइल को `.env` नाम से कॉपी करें (रूट पर).
# 2) Supabase Dashboard → Project Settings → API से नीचे की दो वैल्यू लें।
# 3) असली keys सिर्फ `.env` में रखें — `.env` Git में commit न करें।
# CLI लिंक: रूट पर `supabase link --project-ref <ref>` (ref = URL में xxx.supabase.co का xxx)

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
